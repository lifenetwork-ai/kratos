{{- $renderAsVerification := and .TransientPayload (index .TransientPayload "render_as_verification") -}}
<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>OTP Verification / Xác thực OTP</title>
  </head>
  <body style="font-family: Arial, sans-serif; color: #333333; line-height: 1.6;">
    <p>Dear valued customer,</p>

    {{ if $renderAsVerification }}
    {{ if and .TransientPayload (index .TransientPayload "action_description") }}
    <p>We have received a request to {{ index .TransientPayload "action_description" }}.</p>
    {{ else }}
    <p>We have received a verification request from <strong>{{ .Tenant }}</strong>.</p>
    {{ end }}

    <p>
      For security, please confirm by entering the following One Time Password (OTP) in the app:
    </p>
    {{ else }}
    <p>
      To authenticate, please use the following One Time Password (OTP) from <strong>{{ .Tenant }}</strong>:
    </p>
    {{ end }}

    <p style="font-size: 24px; font-weight: bold; color: #2c3e50;">
      {{ .RegistrationCode }}
    </p>

    <p>
      Your OTP will be valid for <strong>{{ .ExpiresInMinutes }}</strong> minutes.<br />
      Do not share this OTP with anyone. <strong>{{ .Tenant }}</strong> takes your account security very seriously.
    </p>

    {{ if $renderAsVerification }}
    <p>
      If you did not initiate this request, please ignore this email and contact support@lifenetwork.ai.
    </p>
    {{ end }}

    <hr style="margin: 32px 0; border: none; border-top: 1px solid #dddddd;" />

    <p>Kính gửi Quý Khách hàng,</p>

    {{ if $renderAsVerification }}
    {{ if and .TransientPayload (index .TransientPayload "action_description") }}
    <p>Chúng tôi vừa nhận được yêu cầu {{ index .TransientPayload "action_description" }}.</p>
    {{ else }}
    <p>Chúng tôi vừa nhận được yêu cầu xác thực từ <strong>{{ .Tenant }}</strong>.</p>
    {{ end }}

    <p>
      Để bảo mật, vui lòng xác nhận bằng cách nhập mã OTP dưới đây trong ứng dụng:
    </p>
    {{ else }}
    <p>
      Để xác thực, vui lòng sử dụng mã OTP sau từ <strong>{{ .Tenant }}</strong>:
    </p>
    {{ end }}

    <p style="font-size: 24px; font-weight: bold; color: #2c3e50;">
      {{ .RegistrationCode }}
    </p>

    <p>
      Mã OTP của bạn sẽ có hiệu lực trong <strong>{{ .ExpiresInMinutes }}</strong> phút.<br />
      Không chia sẻ OTP này với bất kỳ ai. <strong>{{ .Tenant }}</strong> rất coi trọng sự bảo mật tài khoản của bạn.
    </p>

    {{ if $renderAsVerification }}
    <p>
      Nếu bạn không thực hiện yêu cầu này, vui lòng bỏ qua email và liên hệ support@lifenetwork.ai.
    </p>
    {{ end }}
  </body>
</html>
